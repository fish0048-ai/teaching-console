NEXT_PUBLIC_APP_ENV=development

NEXT_PUBLIC_FIREBASE_API_KEY=你的_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=chunhsin-b2a9d.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=chunhsin-b2a9d
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=chunhsin-b2a9d.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=你的_SENDER_ID
NEXT_PUBLIC_FIREBASE_APP_ID=你的_APP_ID

# Firestore 資料庫名稱（Console 左上角下拉，例如 chunhsindata）
NEXT_PUBLIC_FIREBASE_DATABASE_ID=chunhsindata

# 正式環境（Vercel Production）請改 NEXT_PUBLIC_APP_ENV=production
# 並使用 prod Firebase 專案的對應值
